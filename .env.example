# Meta WhatsApp Cloud API
# Permanent access token from Meta for Developers dashboard
WHATSAPP_TOKEN=

# WhatsApp Business phone number ID (numeric string)
WHATSAPP_PHONE_ID=

# App secret for X-Hub-Signature-256 HMAC verification
WHATSAPP_APP_SECRET=

# Self-chosen random string used during webhook verification setup
WHATSAPP_VERIFY_TOKEN=

# Google Gemini
# From https://aistudio.google.com/app/apikey (free tier available)
GEMINI_API_KEY=

# Vercel Blob — auto-populated by 'vercel env pull' after linking Blob storage
BLOB_READ_WRITE_TOKEN=

# Upstash Redis — auto-populated by 'vercel env pull' after adding Upstash Redis via Vercel Marketplace
# Or set manually from https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
