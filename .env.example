# Twilio WhatsApp
# From https://console.twilio.com
TWILIO_ACCOUNT_SID=          # e.g. ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=           # From Twilio Console dashboard
TWILIO_WHATSAPP_FROM=        # Sandbox: whatsapp:+14155238886

# Your deployed webhook URL (used for Twilio signature verification)
# e.g. https://vercel-conversational-doc-fetcher.vercel.app/api/webhook
WEBHOOK_URL=

# Google Gemini — from https://aistudio.google.com/app/apikey (free tier)
GEMINI_API_KEY=

# Vercel Blob — auto-populated by 'vercel env pull' after linking Blob storage
BLOB_READ_WRITE_TOKEN=

# Upstash Redis — auto-populated by 'vercel env pull' after adding via Vercel Marketplace
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
